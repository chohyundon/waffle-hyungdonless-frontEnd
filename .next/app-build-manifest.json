{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/(home)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(home)/layout.css",
      "static/chunks/app/(home)/layout.js"
    ],
    "/(home)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(home)/page.js"
    ],
    "/(home)/[category]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(home)/[category]/page.css",
      "static/chunks/app/(home)/[category]/page.js"
    ],
    "/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/login/page.css",
      "static/chunks/app/login/page.js"
    ]
  }
}